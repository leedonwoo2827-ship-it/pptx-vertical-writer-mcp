  "keywords": ["pptx", "powerpoint", "vertical", "a3", "proposal", "template", "orchestration", "mcp", "korean"],
  "mcpServers": {
    "pptx-vertical-writer": {
      "command": "python",
      "args": ["-X", "utf8", "${CLAUDE_PLUGIN_ROOT}/server.py"],
